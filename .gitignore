# =============================================================================
# Claude Code Global Settings - .gitignore
# =============================================================================
# This file excludes machine-specific, sensitive, and cache files from version
# control while preserving shareable configuration across machines.
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENTIALS & SECRETS (NEVER COMMIT)
# -----------------------------------------------------------------------------
.credentials.json
.vibe9-token
*.secret
*.key
*.pem

# -----------------------------------------------------------------------------
# LOCAL/MACHINE-SPECIFIC SETTINGS
# -----------------------------------------------------------------------------
# settings.local.json contains machine-specific permissions and paths
settings.local.json

# -----------------------------------------------------------------------------
# CACHE & TEMPORARY FILES
# -----------------------------------------------------------------------------
cache/
debug/
file-history/
ide/
shell-snapshots/
statsig/
telemetry/
todos/
plans/
stats-cache.json
history.jsonl

# -----------------------------------------------------------------------------
# PLUGINS CACHE (plugins themselves are managed separately)
# -----------------------------------------------------------------------------
plugins/cache/
plugins/install-counts-cache.json
plugins/marketplaces/

# -----------------------------------------------------------------------------
# PROJECTS (machine-specific project data)
# -----------------------------------------------------------------------------
projects/

# -----------------------------------------------------------------------------
# DOWNLOADS & MISC
# -----------------------------------------------------------------------------
downloads/
nul

# -----------------------------------------------------------------------------
# OS-SPECIFIC FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor/IDE files
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
.vscode/
.idea/
